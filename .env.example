# n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=Asia/Tokyo

# Database
POSTGRES_USER=n8n
# Replace this before using the stack outside local testing.
POSTGRES_PASSWORD=change-me
POSTGRES_DB=n8n

# Optional: local LLM
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Optional: Slack slash command verification
SLACK_SIGNING_SECRET=replace-with-your-slack-signing-secret

# Do not commit real API keys or n8n credentials.
